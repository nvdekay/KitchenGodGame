# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env.local and fill in. NEVER commit .env.local.
# Variables are validated at boot by src/lib/env.ts — a missing/invalid value
# fails fast with a clear message instead of an undefined-at-runtime surprise.
# ─────────────────────────────────────────────────────────────────────────────

# --- Public (exposed to the browser; safe, anon-key only) -------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Optional — the app derives its origin from each request. Only set this if a
# future feature needs an absolute URL (emails, OG tags).
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Log verbosity for the browser/server logger: debug | info | warn | error
NEXT_PUBLIC_LOG_LEVEL=debug

# --- Server-only (NEVER prefix with NEXT_PUBLIC_) ---------------------------
# Service role key bypasses RLS. Only used in server-side admin operations.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
